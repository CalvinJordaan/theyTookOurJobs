{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "TimeKeeper design tokens — 'Ledger & Dial'. W3C DTCG format. SINGLE SOURCE OF TRUTH for all design values. The CSS custom-property layer (tokens.css) is generated from / mirrors this file and is what components consume via var(). RULE: components reference semantic tokens only; raw primitive values appear nowhere outside this file. No inline CSS anywhere in the product.",
  "primitive": {
    "color": {
      "neutral": {
        "0":   { "$type": "color", "$value": "#ffffff" },
        "50":  { "$type": "color", "$value": "#f8f5ef" },
        "100": { "$type": "color", "$value": "#efeae0" },
        "200": { "$type": "color", "$value": "#e0d8c9" },
        "300": { "$type": "color", "$value": "#c8bda9" },
        "400": { "$type": "color", "$value": "#a89c85" },
        "500": { "$type": "color", "$value": "#877c67" },
        "600": { "$type": "color", "$value": "#6a6051" },
        "700": { "$type": "color", "$value": "#4e463a" },
        "800": { "$type": "color", "$value": "#332e26" },
        "900": { "$type": "color", "$value": "#211d17" },
        "950": { "$type": "color", "$value": "#14110d" }
      },
      "brand": {
        "50":  { "$type": "color", "$value": "#e6f3f2" },
        "100": { "$type": "color", "$value": "#c2e2e0" },
        "200": { "$type": "color", "$value": "#8fcac7" },
        "300": { "$type": "color", "$value": "#57aeaa" },
        "400": { "$type": "color", "$value": "#2a938f" },
        "500": { "$type": "color", "$value": "#0e7c7b" },
        "600": { "$type": "color", "$value": "#0a6463" },
        "700": { "$type": "color", "$value": "#084e4d" },
        "800": { "$type": "color", "$value": "#063a39" },
        "900": { "$type": "color", "$value": "#042625" }
      },
      "green": {
        "100": { "$type": "color", "$value": "#dbede4" },
        "500": { "$type": "color", "$value": "#349468" },
        "600": { "$type": "color", "$value": "#2e7d5b" },
        "700": { "$type": "color", "$value": "#235f45" }
      },
      "amber": {
        "100": { "$type": "color", "$value": "#f8eccf" },
        "500": { "$type": "color", "$value": "#d99a1f" },
        "600": { "$type": "color", "$value": "#c9821a" },
        "700": { "$type": "color", "$value": "#9a6310" }
      },
      "red": {
        "100": { "$type": "color", "$value": "#f7dad6" },
        "500": { "$type": "color", "$value": "#d23f33" },
        "600": { "$type": "color", "$value": "#c2362b" },
        "700": { "$type": "color", "$value": "#97271e" }
      },
      "overlay": {
        "scrim":      { "$type": "color", "$value": "#14110dcc" },
        "ink-08":     { "$type": "color", "$value": "#14110d14" },
        "ink-16":     { "$type": "color", "$value": "#14110d29" },
        "paper-08":   { "$type": "color", "$value": "#f8f5ef14" }
      }
    },
    "font": {
      "family": {
        "display": { "$type": "fontFamily", "$value": ["Fraunces", "Georgia", "serif"] },
        "sans":    { "$type": "fontFamily", "$value": ["IBM Plex Sans", "system-ui", "sans-serif"] },
        "mono":    { "$type": "fontFamily", "$value": ["IBM Plex Mono", "ui-monospace", "monospace"] }
      },
      "weight": {
        "regular":  { "$type": "fontWeight", "$value": 400 },
        "medium":   { "$type": "fontWeight", "$value": 500 },
        "semibold": { "$type": "fontWeight", "$value": 600 },
        "bold":     { "$type": "fontWeight", "$value": 700 },
        "black":    { "$type": "fontWeight", "$value": 900 }
      },
      "size": {
        "2xs": { "$type": "dimension", "$value": "0.6875rem" },
        "xs":  { "$type": "dimension", "$value": "0.75rem" },
        "sm":  { "$type": "dimension", "$value": "0.8125rem" },
        "md":  { "$type": "dimension", "$value": "0.9375rem" },
        "lg":  { "$type": "dimension", "$value": "1.0625rem" },
        "xl":  { "$type": "dimension", "$value": "1.375rem" },
        "2xl": { "$type": "dimension", "$value": "1.75rem" },
        "3xl": { "$type": "dimension", "$value": "2.25rem" },
        "4xl": { "$type": "dimension", "$value": "3rem" },
        "5xl": { "$type": "dimension", "$value": "4rem" }
      },
      "lineHeight": {
        "tight":   { "$type": "number", "$value": 1.1 },
        "snug":    { "$type": "number", "$value": 1.25 },
        "normal":  { "$type": "number", "$value": 1.5 },
        "relaxed": { "$type": "number", "$value": 1.7 }
      },
      "tracking": {
        "tighter": { "$type": "dimension", "$value": "-0.02em" },
        "tight":   { "$type": "dimension", "$value": "-0.01em" },
        "normal":  { "$type": "dimension", "$value": "0em" },
        "wide":    { "$type": "dimension", "$value": "0.04em" },
        "caps":    { "$type": "dimension", "$value": "0.08em" }
      }
    },
    "dimension": {
      "space": {
        "0":  { "$type": "dimension", "$value": "0rem" },
        "1":  { "$type": "dimension", "$value": "0.25rem" },
        "2":  { "$type": "dimension", "$value": "0.5rem" },
        "3":  { "$type": "dimension", "$value": "0.75rem" },
        "4":  { "$type": "dimension", "$value": "1rem" },
        "5":  { "$type": "dimension", "$value": "1.5rem" },
        "6":  { "$type": "dimension", "$value": "2rem" },
        "7":  { "$type": "dimension", "$value": "2.5rem" },
        "8":  { "$type": "dimension", "$value": "3rem" },
        "9":  { "$type": "dimension", "$value": "4rem" },
        "10": { "$type": "dimension", "$value": "6rem" }
      },
      "radius": {
        "none": { "$type": "dimension", "$value": "0rem" },
        "sm":   { "$type": "dimension", "$value": "0.1875rem" },
        "md":   { "$type": "dimension", "$value": "0.375rem" },
        "lg":   { "$type": "dimension", "$value": "0.625rem" },
        "xl":   { "$type": "dimension", "$value": "1rem" },
        "full": { "$type": "dimension", "$value": "9999px" }
      },
      "border": {
        "hairline": { "$type": "dimension", "$value": "1px" },
        "thin":     { "$type": "dimension", "$value": "1.5px" },
        "thick":    { "$type": "dimension", "$value": "2px" },
        "rule":     { "$type": "dimension", "$value": "3px" }
      },
      "size": {
        "control-sm": { "$type": "dimension", "$value": "1.75rem" },
        "control-md": { "$type": "dimension", "$value": "2.25rem" },
        "control-lg": { "$type": "dimension", "$value": "2.75rem" },
        "tap-min":    { "$type": "dimension", "$value": "2.75rem" },
        "sidebar":    { "$type": "dimension", "$value": "16rem" },
        "container":  { "$type": "dimension", "$value": "80rem" }
      }
    },
    "shadow": {
      "xs":   { "$type": "shadow", "$value": { "color": "#14110d14", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" } },
      "sm":   { "$type": "shadow", "$value": { "color": "#14110d1f", "offsetX": "0px", "offsetY": "2px", "blur": "6px", "spread": "-1px" } },
      "md":   { "$type": "shadow", "$value": { "color": "#14110d29", "offsetX": "0px", "offsetY": "8px", "blur": "20px", "spread": "-4px" } },
      "lg":   { "$type": "shadow", "$value": { "color": "#14110d33", "offsetX": "0px", "offsetY": "18px", "blur": "40px", "spread": "-8px" } },
      "dial-glow": { "$type": "shadow", "$value": { "color": "#0e7c7b66", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "4px" } }
    },
    "motion": {
      "duration": {
        "instant": { "$type": "duration", "$value": "0ms" },
        "fast":    { "$type": "duration", "$value": "120ms" },
        "base":    { "$type": "duration", "$value": "220ms" },
        "slow":    { "$type": "duration", "$value": "420ms" },
        "pulse":   { "$type": "duration", "$value": "1600ms" }
      },
      "easing": {
        "standard":   { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] },
        "decelerate": { "$type": "cubicBezier", "$value": [0, 0, 0, 1] },
        "accelerate": { "$type": "cubicBezier", "$value": [0.3, 0, 1, 1] },
        "spring":     { "$type": "cubicBezier", "$value": [0.34, 1.56, 0.64, 1] }
      }
    },
    "zIndex": {
      "base":    { "$type": "number", "$value": 0 },
      "raised":  { "$type": "number", "$value": 10 },
      "sticky":  { "$type": "number", "$value": 100 },
      "overlay": { "$type": "number", "$value": 1000 },
      "modal":   { "$type": "number", "$value": 1100 },
      "toast":   { "$type": "number", "$value": 1200 }
    },
    "breakpoint": {
      "sm": { "$type": "dimension", "$value": "40rem" },
      "md": { "$type": "dimension", "$value": "48rem" },
      "lg": { "$type": "dimension", "$value": "64rem" },
      "xl": { "$type": "dimension", "$value": "80rem" }
    }
  },
  "semantic": {
    "$description": "Aliases consumed by components. Values shown are the LIGHT theme; dark-theme overrides live in tokens.css [data-theme=dark]. Components must reference these, never the primitive layer.",
    "color": {
      "bg": {
        "canvas":        { "$type": "color", "$value": "{primitive.color.neutral.50}" },
        "surface":       { "$type": "color", "$value": "{primitive.color.neutral.0}" },
        "surface-raised":{ "$type": "color", "$value": "{primitive.color.neutral.0}" },
        "sunken":        { "$type": "color", "$value": "{primitive.color.neutral.100}" },
        "inverse":       { "$type": "color", "$value": "{primitive.color.neutral.950}" },
        "accent":        { "$type": "color", "$value": "{primitive.color.brand.500}" },
        "accent-subtle": { "$type": "color", "$value": "{primitive.color.brand.50}" }
      },
      "text": {
        "primary":   { "$type": "color", "$value": "{primitive.color.neutral.900}" },
        "secondary": { "$type": "color", "$value": "{primitive.color.neutral.700}" },
        "muted":     { "$type": "color", "$value": "{primitive.color.neutral.500}" },
        "inverse":   { "$type": "color", "$value": "{primitive.color.neutral.50}" },
        "on-accent": { "$type": "color", "$value": "{primitive.color.neutral.0}" },
        "link":      { "$type": "color", "$value": "{primitive.color.brand.600}" }
      },
      "border": {
        "subtle":  { "$type": "color", "$value": "{primitive.color.neutral.200}" },
        "default": { "$type": "color", "$value": "{primitive.color.neutral.300}" },
        "strong":  { "$type": "color", "$value": "{primitive.color.neutral.900}" },
        "focus":   { "$type": "color", "$value": "{primitive.color.brand.500}" }
      },
      "accent": {
        "default": { "$type": "color", "$value": "{primitive.color.brand.500}" },
        "hover":   { "$type": "color", "$value": "{primitive.color.brand.600}" },
        "active":  { "$type": "color", "$value": "{primitive.color.brand.700}" }
      },
      "status": {
        "running":      { "$type": "color", "$value": "{primitive.color.brand.500}" },
        "success-fg":   { "$type": "color", "$value": "{primitive.color.green.700}" },
        "success-bg":   { "$type": "color", "$value": "{primitive.color.green.100}" },
        "warning-fg":   { "$type": "color", "$value": "{primitive.color.amber.700}" },
        "warning-bg":   { "$type": "color", "$value": "{primitive.color.amber.100}" },
        "danger-fg":    { "$type": "color", "$value": "{primitive.color.red.700}" },
        "danger-bg":    { "$type": "color", "$value": "{primitive.color.red.100}" },
        "danger-solid": { "$type": "color", "$value": "{primitive.color.red.600}" }
      }
    },
    "typography": {
      "display": { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.display}", "fontWeight": "{primitive.font.weight.black}", "fontSize": "{primitive.font.size.5xl}", "lineHeight": "{primitive.font.lineHeight.tight}", "letterSpacing": "{primitive.font.tracking.tighter}" } },
      "h1":      { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.display}", "fontWeight": "{primitive.font.weight.bold}", "fontSize": "{primitive.font.size.3xl}", "lineHeight": "{primitive.font.lineHeight.tight}", "letterSpacing": "{primitive.font.tracking.tight}" } },
      "h2":      { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.display}", "fontWeight": "{primitive.font.weight.semibold}", "fontSize": "{primitive.font.size.2xl}", "lineHeight": "{primitive.font.lineHeight.snug}", "letterSpacing": "{primitive.font.tracking.tight}" } },
      "h3":      { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.sans}", "fontWeight": "{primitive.font.weight.semibold}", "fontSize": "{primitive.font.size.xl}", "lineHeight": "{primitive.font.lineHeight.snug}", "letterSpacing": "{primitive.font.tracking.normal}" } },
      "body":    { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.sans}", "fontWeight": "{primitive.font.weight.regular}", "fontSize": "{primitive.font.size.md}", "lineHeight": "{primitive.font.lineHeight.normal}", "letterSpacing": "{primitive.font.tracking.normal}" } },
      "body-sm": { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.sans}", "fontWeight": "{primitive.font.weight.regular}", "fontSize": "{primitive.font.size.sm}", "lineHeight": "{primitive.font.lineHeight.normal}", "letterSpacing": "{primitive.font.tracking.normal}" } },
      "label":   { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.sans}", "fontWeight": "{primitive.font.weight.medium}", "fontSize": "{primitive.font.size.xs}", "lineHeight": "{primitive.font.lineHeight.snug}", "letterSpacing": "{primitive.font.tracking.normal}" } },
      "overline":{ "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.sans}", "fontWeight": "{primitive.font.weight.semibold}", "fontSize": "{primitive.font.size.2xs}", "lineHeight": "{primitive.font.lineHeight.snug}", "letterSpacing": "{primitive.font.tracking.caps}" } },
      "timer":   { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.mono}", "fontWeight": "{primitive.font.weight.medium}", "fontSize": "{primitive.font.size.4xl}", "lineHeight": "{primitive.font.lineHeight.tight}", "letterSpacing": "{primitive.font.tracking.tight}" } },
      "data":    { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.mono}", "fontWeight": "{primitive.font.weight.regular}", "fontSize": "{primitive.font.size.sm}", "lineHeight": "{primitive.font.lineHeight.snug}", "letterSpacing": "{primitive.font.tracking.normal}" } }
    },
    "elevation": {
      "card":    { "$type": "shadow", "$value": "{primitive.shadow.sm}" },
      "popover": { "$type": "shadow", "$value": "{primitive.shadow.md}" },
      "modal":   { "$type": "shadow", "$value": "{primitive.shadow.lg}" }
    },
    "motion": {
      "control":    { "$type": "duration", "$value": "{primitive.motion.duration.fast}" },
      "transition": { "$type": "duration", "$value": "{primitive.motion.duration.base}" },
      "enter":      { "$type": "duration", "$value": "{primitive.motion.duration.slow}" }
    },
    "focus": {
      "ring-width":  { "$type": "dimension", "$value": "{primitive.dimension.border.thick}" },
      "ring-offset": { "$type": "dimension", "$value": "{primitive.dimension.space.1}" },
      "ring-color":  { "$type": "color", "$value": "{primitive.color.brand.500}" }
    }
  }
}
