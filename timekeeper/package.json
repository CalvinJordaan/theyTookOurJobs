{
  "name": "timekeeper",
  "private": true,
  "version": "0.1.0",
  "description": "MCP-native, event-native time-tracking — a Harvest rebuild for agents and humans.",
  "engines": { "node": ">=24" },
  "scripts": {
    "dev": "pnpm --filter @timekeeper/server dev",
    "dev:all": "pnpm --parallel --filter @timekeeper/server --filter @timekeeper/web dev",
    "build": "pnpm --filter @timekeeper/shared build && pnpm --filter @timekeeper/design-tokens build && pnpm --parallel --filter @timekeeper/server --filter @timekeeper/web build",
    "typecheck": "pnpm --parallel --filter @timekeeper/server --filter @timekeeper/web typecheck && pnpm --filter @timekeeper/shared typecheck",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:style": "stylelint 'apps/web/src/**/*.module.css'",
    "test": "pnpm --parallel --filter @timekeeper/server --filter @timekeeper/web test",
    "db:migrate": "pnpm --filter @timekeeper/server db:migrate",
    "db:seed": "pnpm --filter @timekeeper/server db:seed",
    "db:studio": "pnpm --filter @timekeeper/server db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^37.0.0",
    "typescript": "^5.7.0"
  }
}
