# Database
DATABASE_URL=postgresql://timekeeper:timekeeper@localhost:5432/timekeeper

# Server
PORT=3000
NODE_ENV=development

# CORS — origin of the SPA in dev
CORS_ORIGIN=http://localhost:5173

# Static bearer-token auth (MVP)
# Format: comma-separated token:userId pairs
# e.g. "my-agent-token:1,my-human-token:2"
MCP_BEARER_TOKENS=demo-token-admin:1,demo-token-member:2

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
